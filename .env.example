GEMINI_API_KEY=votre_cle_api_gemini_ici
VITE_SUPABASE_URL=votre_url_supabase_ici
VITE_SUPABASE_ANON_KEY=votre_cle_anon_supabase_ici
ELEVENLABS_API_KEY=votre_cle_api_elevenlabs_ici_optionnel

# Upstash Redis pour le rate limiting des Edge Functions
# (https://upstash.com -> Create database -> Redis -> onglet REST API)
# Si non configures, le rate limiting est desactive (fail-open en dev).
UPSTASH_REDIS_REST_URL=https://<votre-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=votre_token_upstash_ici
